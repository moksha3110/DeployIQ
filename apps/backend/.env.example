NODE_ENV=development
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
BACKEND_URL=http://localhost:4000
# Only needed for auto-deploy-on-push to actually work (GitHub must be able
# to reach this URL) — point it at a tunnel (ngrok, localtunnel, etc.).
# Leave as localhost otherwise; GitHub will reject webhook registration with
# a clear error rather than silently failing (see docs/API.md#webhooks).
PUBLIC_WEBHOOK_URL=http://localhost:4000

# Started via infra/docker/docker-compose.yml
DATABASE_URL=postgresql://platform:platform@localhost:5432/platform?schema=public
REDIS_URL=redis://localhost:6379

# From a GitHub OAuth App (https://github.com/settings/developers -> New OAuth App).
# Homepage URL: http://localhost:5173
# Authorization callback URL: http://localhost:4000/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Optional — leave unset and builds stay local-only (no registry push),
# which is enough to deploy onto Minikube's own Docker daemon.
DOCKER_REGISTRY=docker.io
DOCKER_REGISTRY_USERNAME=
DOCKER_REGISTRY_PASSWORD=

# Optional — leave unset and failed deployments just skip AI diagnosis.
# From https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Optional — ships structured logs to Loki (infra/loki/values.yaml) so they
# show up alongside metrics in Grafana. Logs go to the console either way.
LOKI_ENABLED=false
